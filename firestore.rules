rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function belongsToCompany(companyId) {
      return isSignedIn() && request.auth.token.companyId == companyId;
    }

    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow write: if false;

      match /resumes/{resumeId} {
        allow read, create, update, delete: if belongsToCompany(companyId);
      }

      match /resumeAnalyses/{analysisId} {
        allow read, create, update, delete: if belongsToCompany(companyId);
      }

      match /shortlists/{shortlistId} {
        allow read, create, update, delete: if belongsToCompany(companyId);
      }
    }
  }
}
